---
export const prerender = false;

import "../styles/global.css";
import { fetchStreamingId } from "../lib/streaming";
import { env } from "cloudflare:workers";
import ErrorMessage from "../components/ErrorMessage.astro";
import NoStream from "../components/NoStream.astro";
import StreamPlayer from "../components/StreamPlayer.astro";
import BraveToast from "../components/BraveToast.astro";

const workerUrl = env.WORKER_URL ?? "";
const authToken = env.WORKER_AUTH_TOKEN ?? "";

const url = new URL(Astro.request.url);
const queryId = url.searchParams.get("id");
const hostname = url.hostname;

let streamingId: string | null = null;
let updatedAt: string | null = null;
let errorMessage: string | null = null;

if (queryId) {
  streamingId = queryId;
} else if (!workerUrl || !authToken) {
  errorMessage = "Configuración incompleta, comuníquese con el administrador.";
} else {
  const result = await fetchStreamingId(workerUrl, authToken);
 
  if (result.ok) {
    updatedAt = result.data.updated_at;
    streamingId =
      result.data.streaming_id !== "NOT_FOUND"
        ? result.data.streaming_id
        : null;
  } else {
    errorMessage = result.error;
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" />
    <title>SapoPerro Ruso</title>
  </head>
  <body class="m-0 h-dvh w-screen overflow-hidden bg-[#0e0e10] text-white">
    {errorMessage && <ErrorMessage message={errorMessage} />}

    {!errorMessage && !streamingId && <NoStream updatedAt={updatedAt} />}

    {streamingId && <StreamPlayer streamingId={streamingId} hostname={hostname} />}

    {streamingId && <BraveToast />}
  </body>
</html>
