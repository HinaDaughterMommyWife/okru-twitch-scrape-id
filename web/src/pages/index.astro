---
export const prerender = false;

import "../styles/global.css";
import { fetchStreamingId } from "../lib/streaming";
import { env } from "cloudflare:workers";

const workerUrl = env.WORKER_URL ?? "";
const authToken = env.WORKER_AUTH_TOKEN ?? "";

const url = new URL(Astro.request.url);
const queryId = url.searchParams.get("id");
const hostname = url.hostname;

let streamingId: string | null = null;
let errorMessage: string | null = null;

if (queryId) {
  streamingId = queryId;
} else if (!workerUrl || !authToken) {
  errorMessage = "Missing WORKER_URL or WORKER_AUTH_TOKEN configuration";
} else {
  const result = await fetchStreamingId(workerUrl, authToken);
  if (result.ok) {
    streamingId =
      result.data.streaming_id !== "NOT_FOUND"
        ? result.data.streaming_id
        : null;
  } else {
    errorMessage = result.error;
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ok.ru Live Stream</title>
  </head>
  <body class="m-0 h-screen w-screen overflow-hidden bg-[#0e0e10] text-white">
    {errorMessage && (
      <div class="flex h-full items-center justify-center">
        <p class="text-red-400">Error: {errorMessage}</p>
      </div>
    )}

    {!errorMessage && !streamingId && (
      <div class="flex h-full items-center justify-center">
        <p class="text-gray-400">No active live stream.</p>
      </div>
    )}

    {streamingId && (
      <div class="flex h-full flex-col md:flex-row">
        {/* Video ok.ru */}
        <div class="w-full shrink-0 aspect-video md:aspect-auto md:h-full md:flex-1">
          <iframe
            title={`video-${streamingId}`}
            class="h-full w-full border-0"
            src={`//ok.ru/videoembed/${streamingId}?nochat=1&autoplay=1`}
            allow="autoplay"
            allowfullscreen
          ></iframe>
        </div>

        {/* Twitch chat */}
        <div class="min-h-0 w-full flex-1 md:h-full md:flex-none md:w-85">
          <iframe
            id="twitch-chat-embed"
            title="chat"
            class="h-full w-full border-0"
            src={`https://www.twitch.tv/embed/thedarkraimola/chat?darkpopout&parent=${hostname}`}
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    )}

    <div
      id="brave-toast"
      class="pointer-events-none fixed bottom-4 left-1/2 z-50 w-[90%] -translate-x-1/2 md:w-auto md:left-auto md:right-4 md:translate-x-0 opacity-0 transition-opacity duration-300"
    >
      <div class="pointer-events-auto flex items-center gap-0.5 md:gap-2 rounded-lg bg-yellow-500 px-4 py-3 text-sm font-medium text-black shadow-lg">
        <span>Desactiva los escudos de Brave para usar el chat, perdón xd 🛡️</span>
        <button id="brave-toast-close" class="ml-px cursor-pointer text-black/60 hover:text-black" aria-label="Cerrar">&times;</button>
      </div>
    </div>

    <script>
      function hideToast() {
        const toast = document.getElementById("brave-toast");
        if (!toast) return;
        toast.classList.remove("opacity-100");
        toast.classList.add("opacity-0");
      }

      if ((navigator as any).brave && typeof (navigator as any).brave.isBrave === "function") {
        (navigator as any).brave.isBrave().then((isBrave: boolean) => {
          if (!isBrave) return;
          const key = "brave_toast_count";
          const count = parseInt(localStorage.getItem(key) ?? "0", 10);
          if (count >= 5) return;
          localStorage.setItem(key, String(count + 1));
          const toast = document.getElementById("brave-toast");
          if (!toast) return;
          toast.classList.remove("opacity-0");
          toast.classList.add("opacity-100");
          setTimeout(hideToast, 10000);
          document.getElementById("brave-toast-close")?.addEventListener("click", hideToast);
        });
      }
    </script>
  </body>
</html>
